            <variable name="fAccum">
              <type>
                <LREAL />
              </type>
              <initialValue>
                <simpleValue value="0.0" />
              </initialValue>
            </variable>
            <addData>
              <data name="http://www.3s-software.com/plcopenxml/interfaceasplaintext" handleUnknown="implementation">
                <InterfaceAsPlainText>
                  <xhtml xmlns="http://www.w3.org/1999/xhtml">FUNCTION F_CreateCPULoad
VAR_INPUT
	nIterations : DINT := 500000; (* Tune this to adjust load *)
END_VAR

VAR
	iIter  : DINT;
	fAccum : LREAL := 0.0;
END_VAR</xhtml>
                </InterfaceAsPlainText>
              </data>
            </addData>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">FOR iIter := 1 TO nIterations DO
	fAccum := fAccum + SQRT(DINT_TO_LREAL(iIter));
END_FOR</xhtml>
          </ST>
        </body>
