            <addData>
              <data name="http://www.3s-software.com/plcopenxml/interfaceasplaintext" handleUnknown="implementation">
                <InterfaceAsPlainText>
                  <xhtml xmlns="http://www.w3.org/1999/xhtml">FUNCTION F_CreateCPULoad
VAR_INPUT
	nIterations : DINT := 500000; (* Tune this to adjust load *)
END_VAR

VAR
	iIter  : DINT;
	fAccum : LREAL := 0.0;
END_VAR</xhtml>
                </InterfaceAsPlainText>
              </data>
            </addData>
          </inputVars>
          <localVars>
            <variable name="iIter">
              <type>
