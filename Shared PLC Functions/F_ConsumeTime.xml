              <type>
                <UDINT />
              </type>
            </variable>
            <addData>
              <data name="http://www.3s-software.com/plcopenxml/interfaceasplaintext" handleUnknown="implementation">
                <InterfaceAsPlainText>
                  <xhtml xmlns="http://www.w3.org/1999/xhtml">FUNCTION F_ConsumeTime
VAR_INPUT
	Us		:UDINT;
END_VAR
VAR
		tCurr, tEnd : T_DCTIME64;
END_VAR</xhtml>
                </InterfaceAsPlainText>
              </data>
            </addData>
          </inputVars>
          <localVars>
            <variable name="tCurr">
              <type>
                <derived name="T_DCTIME64" />
              </type>
            </variable>
            <variable name="tEnd">
              <type>
                <derived name="T_DCTIME64" />
              </type>
            </variable>
            <addData>
              <data name="http://www.3s-software.com/plcopenxml/interfaceasplaintext" handleUnknown="implementation">
                <InterfaceAsPlainText>
                  <xhtml xmlns="http://www.w3.org/1999/xhtml">FUNCTION F_ConsumeTime
VAR_INPUT
	Us		:UDINT;
END_VAR
VAR
		tCurr, tEnd : T_DCTIME64;
END_VAR</xhtml>
                </InterfaceAsPlainText>
              </data>
            </addData>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml xmlns="http://www.w3.org/1999/xhtml">tCurr := F_GetActualDcTime64();
tEnd  := tCurr + (Us * EC_DCTIME_TICKSPERMSEC64 / 1000);
WHILE (tCurr &lt; tEnd) DO
	tCurr := F_GetActualDcTime64();
END_WHILE

</xhtml>
          </ST>
        </body>
